# ===========================================
# 个人网站系统 - 环境变量示例
# 复制为 .env.local 并填入实际值
# ===========================================

# ---------- 数据库 ----------
# 开发环境：SQLite 本地文件（默认）
# DATABASE_URL="file:./local.db"

# 生产环境：Turso 边缘 SQLite（从 Turso 控制台获取）
# DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# ---------- 邮件服务 (Resend) ----------
# 联系表单通知邮件（必填以发送站主通知）
# RESEND_API_KEY="re_xxxxxxxx"

# 站主邮箱 - 接收联系表单提交
# SITE_OWNER_EMAIL="your@email.com"

# 发件人邮箱（可选，默认 onboarding@resend.dev）
# CONTACT_FROM_EMAIL="noreply@yourdomain.com"

# ---------- 文件存储 (Vercel Blob) ----------
# 简历 PDF 签名 URL（可选，未配置时使用静态 /resume.pdf）
# BLOB_READ_WRITE_TOKEN="vercel_blob_xxx"
# RESUME_BLOB_PATH="resume.pdf"

# ---------- 应用配置 ----------
# SITE_URL="https://your-site.vercel.app"

# ---------- 管理接口鉴权 ----------
# DELETE /api/guestbook/[id] 需 Bearer Token，未配置时返回 503
# ADMIN_API_KEY="your-secret-admin-key"

# ---------- 管理接口鉴权 (DELETE /api/guestbook/[id]) ----------
# 若未配置，该接口不应对外暴露
# ADMIN_API_KEY="your-secret-admin-key"

# ---------- 验证层：联系表单验证码（可选） ----------
# 未配置时使用简单数学题验证；配置后可在 API 中接入 Cloudflare Turnstile
# TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""

# ---------- 验证层：详细履历访问密码 ----------
# 设置后 /resume/detailed 需输入此密码方可查看 content/resume/detailed.json
# RESUME_ACCESS_PASSWORD=""

# ---------- 留言板 AI 审核（阿里云百炼 / 千问 Qwen） ----------
# 配置后启用：新留言经千问大模型判断是否违反公序良俗，通过则直接展示，否则不展示
# 密钥与 URL 仅填写在 .env.local 或部署平台环境变量中，切勿写入代码或提交到仓库
# DASHSCOPE_API_KEY=""
# 可选：自定义 API 地址，未设置则使用默认 DashScope 地址
# DASHSCOPE_BASE_URL=""
# 可选：模型名称，默认 qwen3.5
# DASHSCOPE_MODEL="qwen3.5"
